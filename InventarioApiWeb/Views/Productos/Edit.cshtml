@model CreateProductViewModel
@{
    ViewData["Title"] = "Editar Producto";
    int productId = ViewBag.ProductId;
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="d-flex align-items-center mb-4">
            <a href="/Productos" class="btn btn-outline-secondary btn-sm me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h4 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>Editar Producto</h4>
                <p class="text-muted small mb-0">Producto #@productId</p>
            </div>
        </div>

        <div class="card">
            <div class="card-body p-4">
                <form asp-action="Edit" asp-controller="Productos" asp-route-id="@productId" method="post">
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label asp-for="CurrentStock" class="form-label fw-semibold"></label>
                            <input asp-for="CurrentStock" class="form-control" type="number" min="0" />
                            <span asp-validation-for="CurrentStock" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="MinimumStock" class="form-label fw-semibold"></label>
                            <input asp-for="MinimumStock" class="form-control" type="number" min="0" />
                            <span asp-validation-for="MinimumStock" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 pt-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Guardar Cambios
                        </button>
                        <a href="/Productos" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>