@model List<LowStockViewModel>
@{
    ViewData["Title"] = "Stock Bajo";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-danger">
            <i class="bi bi-exclamation-triangle me-2"></i>Reporte de Stock Bajo
        </h4>
        <p class="text-muted small mb-0">Productos que requieren reposición</p>
    </div>
    <a href="/Productos" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-check-circle text-success" style="font-size:3.5rem"></i>
            <h5 class="mt-3 fw-semibold">¡Todo en orden!</h5>
            <p class="text-muted">No hay productos con stock bajo}</p>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger d-flex align-items-center mb-4">
        <i class="bi bi-exclamation-octagon-fill me-3 fs-4"></i>
        <strong>@Model.Count producto(s) requieren reposicion</strong>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Producto</th>
                            <th>Stock Actual</th>
                            <th>Stock Minimo</th>
                            <th>Déficit</th>
                            <th>Progreso</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.OrderBy(x => x.CurrentStock))
                        {
                            int pct = p.MinimumStock > 0
                            ? (int)Math.Min(100, (double)p.CurrentStock / p.MinimumStock * 100)
                            : 0;
                            string barColor = pct < 30 ? "bg-danger" : pct < 60 ? "bg-warning" : "bg-success";
                            <tr>
                                <td class="text-muted small">@p.Id</td>
                                <td class="fw-semibold">@p.Name</td>
                                <td class="text-danger fw-bold">@p.CurrentStock</td>
                                <td class="text-muted">@p.MinimumStock</td>
                                <td><span class="badge bg-danger rounded-pill">@p.StockDeficit unidades</span></td>
                                <td style="min-width:120px">
                                    <div class="progress" style="height:8px">
                                        <div class="progress-bar @barColor" style="width:@pct%"></div>
                                    </div>
                                    <small class="text-muted">@pct%</small>
                                </td>
                                <td>
                                    <a href="/Productos/Editar/@p.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil me-1"></i>Editar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}