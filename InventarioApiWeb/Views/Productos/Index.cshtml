@model List<ProductViewModel>
@{
    ViewData["Title"] = "Productos";
    int lowStockCount = ViewBag.LowStockCount ?? 0;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-grid me-2 text-primary"></i>Gestión de Productos</h4>
        <p class="text-muted small mb-0">@Model.Count producto(s) registrado(s)</p>
    </div>
    <div class="d-flex gap-2">
        @if (lowStockCount > 0)
        {
            <a href="/Productos/StockBajo" class="btn btn-warning btn-sm">
                <i class="bi bi-exclamation-triangle me-1"></i>@lowStockCount con stock bajo
            </a>
        }
        <a href="/Productos/Crear" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Producto
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100 p-3">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="text-muted small mb-1 text-uppercase fw-semibold">Total Productos</p>
                    <h3 class="fw-bold mb-0">@Model.Count</h3>
                </div>
                <i class="bi bi-box stat-icon text-primary"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card danger h-100 p-3">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="text-muted small mb-1 text-uppercase fw-semibold">Requieren Reposición</p>
                    <h3 class="fw-bold mb-0 text-danger">@lowStockCount</h3>
                </div>
                <i class="bi bi-exclamation-triangle stat-icon text-danger"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card success h-100 p-3">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="text-muted small mb-1 text-uppercase fw-semibold">Stock OK</p>
                    <h3 class="fw-bold mb-0 text-success">@(Model.Count - lowStockCount)</h3>
                </div>
                <i class="bi bi-check-circle stat-icon text-success"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100 p-3">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="text-muted small mb-1 text-uppercase fw-semibold">Valor Inventario</p>
                    <h3 class="fw-bold mb-0">$@Model.Sum(p => p.Price * p.CurrentStock).ToString("N2")</h3>
                </div>
                <i class="bi bi-currency-dollar stat-icon text-primary"></i>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white d-flex align-items-center justify-content-between py-3">
        <span><i class="bi bi-table me-2"></i>Listado de Productos</span>
        <input type="text" id="searchInput" class="form-control form-control-sm w-auto"
               placeholder="Buscar..." style="min-width:200px" />
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox" style="font-size:3rem"></i>
                <p class="mt-2">No hay productos registrados.</p>
                <a href="/Productos/Crear" class="btn btn-primary btn-sm">Crear primer producto</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="productsTable">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Producto</th>
                            <th>Precio</th>
                            <th>Stock Actual</th>
                            <th>Stock Mínimo</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td class="text-muted small">@p.Id</td>
                                <td class="fw-semibold">@p.Name</td>
                                <td>$@p.Price.ToString("N2")</td>
                                <td class="@(p.RequiresRestocking ? "text-danger fw-bold" : "text-success fw-bold")">
                                    @p.CurrentStock
                                </td>
                                <td class="text-muted">@p.MinimumStock</td>
                                <td>
                                    @if (p.RequiresRestocking)
                                    {
                                        <span class="badge badge-stock-low rounded-pill px-2 py-1">
                                            <i class="bi bi-exclamation-circle me-1"></i>Reponer
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-stock-ok rounded-pill px-2 py-1">
                                            <i class="bi bi-check-circle me-1"></i>OK
                                        </span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a href="/Productos/Editar/@p.Id" class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    @if (Context.Session.GetString("Role") == "Admin")
                                    {
                                        <form action="/Productos/Eliminar/@p.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('¿Eliminar @p.Name?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('#productsTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });
    </script>
}