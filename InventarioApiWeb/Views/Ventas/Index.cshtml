@model List<SaleViewModel>
@{
    ViewData["Title"] = "Ventas";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-cart3 me-2 text-primary"></i>Historial de Ventas</h4>
        <p class="text-muted small mb-0">@Model.Count venta(s) registrada(s)</p>
    </div>
    <a href="/Ventas/Registrar" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Registrar Venta
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card h-100 p-3">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="text-muted small mb-1 text-uppercase fw-semibold">Total Ventas</p>
                    <h3 class="fw-bold mb-0">@Model.Count</h3>
                </div>
                <i class="bi bi-receipt stat-icon text-primary"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card success h-100 p-3">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="text-muted small mb-1 text-uppercase fw-semibold">Ingresos Totales</p>
                    <h3 class="fw-bold mb-0 text-success">$@Model.Sum(s => s.TotalAmount).ToString("N2")</h3>
                </div>
                <i class="bi bi-cash-stack stat-icon text-success"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card h-100 p-3">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="text-muted small mb-1 text-uppercase fw-semibold">Promedio por Venta</p>
                    <h3 class="fw-bold mb-0">
                        $@(Model.Any() ? (Model.Sum(s => s.TotalAmount) / Model.Count).ToString("N2") : "0.00")
                    </h3>
                </div>
                <i class="bi bi-graph-up stat-icon text-primary"></i>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white py-3 fw-semibold">
        <i class="bi bi-table me-2"></i>Registro de Ventas
    </div>
    <div class="card-body p-0">
        @if (Context.Session.GetString("Role") == "Employee")
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-cart-x" style="font-size:3rem"></i>
                <p class="mt-2">Debes ser usuario Admin para ver el historial de ventas.</p>
            </div>
        }   
        else if (!Model.Any())
        {
            //var rol = Context.Session.GetString("Role");
            <div class="text-center py-5 text-muted">
                <i class="bi bi-cart-x" style="font-size:3rem"></i>
                <p class="mt-2">No hay ventas registradas aún.</p>
                <!--<p class="mt-2">Tu rol es +</p>-->
                <a href="/Ventas/Registrar" class="btn btn-primary btn-sm">Registrar primera venta</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Fecha</th>
                            <th>Vendedor</th>
                            <th>Productos</th>
                            <th>Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="text-muted small">@s.Id</td>
                                <td>
                                    <span class="fw-semibold">@s.SaleDate.ToLocalTime().ToString("dd/MM/yyyy")</span>
                                    <br /><small class="text-muted">@s.SaleDate.ToLocalTime().ToString("HH:mm")</small>
                                </td>
                                <td><i class="bi bi-person me-1 text-muted"></i>@s.SoldBy</td>
                                <td>
                                    @foreach (var item in s.Items)
                                    {
                                        <span class="badge bg-light text-dark border me-1">
                                            @item.ProductName × @item.Quantity
                                        </span>
                                    }
                                </td>
                                <td class="fw-bold text-success">$@s.TotalAmount.ToString("N2")</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-secondary"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#detail-@s.Id">
                                        <i class="bi bi-chevron-down"></i>
                                    </button>
                                </td>
                            </tr>
                            <tr class="collapse" id="detail-@s.Id">
                                <td colspan="6" class="bg-light p-0">
                                    <div class="p-3">
                                        <table class="table table-sm mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Producto</th>
                                                    <th>Cant.</th>
                                                    <th>P. Unitario</th>
                                                    <th>Subtotal</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in s.Items)
                                                {
                                                    <tr>
                                                        <td>@item.ProductName</td>
                                                        <td>@item.Quantity</td>
                                                        <td>$@item.UnitPrice.ToString("N2")</td>
                                                        <td class="fw-semibold">$@item.Subtotal.ToString("N2")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                            <tfoot>
                                                <tr>
                                                    <td colspan="3" class="text-end fw-bold">Total:</td>
                                                    <td class="fw-bold text-success">$@s.TotalAmount.ToString("N2")</td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>